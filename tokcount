#!/bin/bash
# tokcount — estimate token counts for LLM context planning
#
# Fast, streaming token counter. Never loads entire files into memory.
#
# Usage:
#   tokcount file.md                   # fast estimate (chars/4)
#   tokcount -a file.md                # accurate (tiktoken)
#   tokcount -m gpt-4o file.md         # check model fit
#   cat huge.txt | tokcount            # stdin pipe
#   tokcount -q file.md                # quiet — just the number
#   tokcount *.md                      # multiple files
#   tokcount -r ./docs/                # recursive directory
#   tokcount --json file.md            # JSON output
#   tokcount --list-models             # show known models
#
# Flags:
#   -h, --help         Show usage
#   -a, --accurate     Use tiktoken for exact count (needs: pip install tiktoken)
#   -m MODEL           Check against model's context window (repeatable)
#   -q, --quiet        Just print the token number (pipeable)
#   -r, --recursive    Recurse into directories
#   -t TOKENIZER       Tokenizer encoding (cl100k_base, o200k_base)
#   --json             JSON output for scripting
#   --list-models      List known models and context windows

set -e
set -o pipefail

# ---------------------------------------------------------------------------
# Resolve paths
# ---------------------------------------------------------------------------
SCRIPT_DIR="$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")")"
CORE_PY="${SCRIPT_DIR}/_tokcount_core.py"

if [ ! -f "$CORE_PY" ]; then
    echo "error: _tokcount_core.py not found at ${CORE_PY}" >&2
    exit 1
fi

# ---------------------------------------------------------------------------
# Colors (disabled if not a terminal or if piping/quiet)
# ---------------------------------------------------------------------------
if [ -t 1 ]; then
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    RED='\033[0;31m'
    CYAN='\033[0;36m'
    BLUE='\033[0;34m'
    BOLD='\033[1m'
    DIM='\033[2m'
    NC='\033[0m'
else
    GREEN='' YELLOW='' RED='' CYAN='' BLUE='' BOLD='' DIM='' NC=''
fi

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------
usage() {
    echo -e "${BOLD}tokcount${NC} — estimate token counts for LLM context planning"
    echo ""
    echo -e "${BOLD}USAGE${NC}"
    echo "  tokcount [FLAGS] [FILES...]"
    echo "  command | tokcount [FLAGS]"
    echo ""
    echo -e "${BOLD}FLAGS${NC}"
    echo "  -h, --help         Show this help"
    echo "  -a, --accurate     Exact count via tiktoken (slower, needs tiktoken)"
    echo "  -m MODEL           Check fit against model context window (repeatable)"
    echo "  -q, --quiet        Print only the token number (for piping)"
    echo "  -r, --recursive    Recurse into directories"
    echo "  -t TOKENIZER       Encoding: cl100k_base (default), o200k_base"
    echo "  --json             Machine-readable JSON output"
    echo "  --list-models      Show all known models and context sizes"
    echo ""
    echo -e "${BOLD}EXAMPLES${NC}"
    echo "  tokcount README.md                # fast estimate"
    echo "  tokcount -a -m gpt-4o big.txt     # accurate + model check"
    echo "  cat doc.md | tokcount -q          # pipe, just the number"
    echo "  tokcount -r ./docs/ --json        # recursive, JSON"
    echo "  tokcount *.md -m claude-3.5-sonnet"
    echo ""
    echo -e "${DIM}Fast estimate uses chars/4 heuristic (~95% accurate for English).${NC}"
    echo -e "${DIM}Accurate mode streams through tiktoken in 256KB chunks.${NC}"
    exit 0
}

# ---------------------------------------------------------------------------
# Parse arguments — pass through to Python, but intercept -h/--help
# ---------------------------------------------------------------------------
ARGS=()
QUIET=false
JSON=false

for arg in "$@"; do
    case "$arg" in
        -h|--help)
            usage
            ;;
        -q|--quiet)
            QUIET=true
            ARGS+=("$arg")
            ;;
        --json)
            JSON=true
            ARGS+=("$arg")
            ;;
        *)
            ARGS+=("$arg")
            ;;
    esac
done

# ---------------------------------------------------------------------------
# Run the Python core
# ---------------------------------------------------------------------------

# Capture Python output
if [ -p /dev/stdin ] || [ ! -t 0 ]; then
    # stdin is a pipe — pass it through
    OUTPUT=$(python3 "$CORE_PY" "${ARGS[@]}" 2>&1) || {
        echo "$OUTPUT" >&2
        exit 1
    }
else
    OUTPUT=$(python3 "$CORE_PY" "${ARGS[@]}" 2>&1) || {
        echo "$OUTPUT" >&2
        exit 1
    }
fi

# ---------------------------------------------------------------------------
# If quiet or JSON, pass through raw
# ---------------------------------------------------------------------------
if $QUIET || $JSON; then
    echo "$OUTPUT"
    exit 0
fi

# ---------------------------------------------------------------------------
# Colorize the human-readable output
# ---------------------------------------------------------------------------
while IFS= read -r line; do
    case "$line" in
        file:*)
            echo -e "${BOLD}${BLUE}${line}${NC}"
            ;;
        size:*|chars:*)
            echo -e "${DIM}${line}${NC}"
            ;;
        "tokens (est):"*)
            echo -e "${CYAN}${line}${NC}"
            ;;
        "tokens ("*)
            echo -e "${BOLD}${CYAN}${line}${NC}"
            ;;
        "--- total ---")
            echo -e "\n${BOLD}${BLUE}--- total ---${NC}"
            ;;
        "files:"*)
            echo -e "${BOLD}${line}${NC}"
            ;;
        CTX_FIT:*:OK)
            # Parse: CTX_FIT:model:ctx:OK
            model=$(echo "$line" | cut -d: -f2)
            ctx=$(echo "$line" | cut -d: -f3)
            echo -e "${GREEN}  ✓${NC} fits ${BOLD}${model}${NC} context (${ctx})"
            ;;
        CTX_FIT:*:OVER:*)
            # Parse: CTX_FIT:model:ctx:OVER:amount
            model=$(echo "$line" | cut -d: -f2)
            ctx=$(echo "$line" | cut -d: -f3)
            over=$(echo "$line" | cut -d: -f5)
            echo -e "${RED}  ⚠${NC} exceeds ${BOLD}${model}${NC} context (${ctx}) by ${RED}~${over} tokens${NC}"
            ;;
        "")
            echo ""
            ;;
        *)
            echo "$line"
            ;;
    esac
done <<< "$OUTPUT"
